# Staging server env file — lives at the SCP destination path alongside docker-compose.staging.yml
# (see .github/workflows/cd.yml). Copy to `.env` ON THE SERVER and fill in real values; never
# commit the filled-in version. This file intentionally does NOT contain application secrets
# (DATABASE_URL, SESSION_SECRET, CSRF_SECRET, REDIS_URL, LINE_*) — those are resolved at container
# start by the Infisical CLI baked into the image (`infisical run -- node dist/main.js`), sourced
# from Infisical itself, not from a file on this box. This file only supplies what
# docker-compose.staging.yml needs to locate the image and reach Infisical.

# GHCR namespace the image was pushed to (matches the GitHub org/user, lowercase).
GHCR_OWNER=REPLACE_YOUR_GITHUB_USERNAME

# Immutable commit-SHA tag the CI workflow built and pushed. The CD workflow overwrites/exports
# this before `docker-compose up -d`; the value below is a placeholder only.
IMAGE_TAG=REPLACE_WITH_COMMIT_SHA

# Infisical machine-identity token, scoped read-only to this project/environment. Injected by
# the CD workflow via SSH env from a GitHub Secret (INFISICAL_TOKEN) — never typed into this
# file on a real server either; treat this line as documentation of the variable's existence.
INFISICAL_TOKEN=REPLACE_WITH_INFISICAL_MACHINE_IDENTITY_TOKEN

# Infisical project + environment slug to pull secrets from.
INFISICAL_PROJECT_ID=REPLACE_WITH_INFISICAL_PROJECT_ID
INFISICAL_ENV=staging

# ---------------------------------------------------------------------------
# Values that MUST be set to these exact staging values inside Infisical itself (not here) —
# documented here so the CI/CD owner can verify them without server access:
# ---------------------------------------------------------------------------
#   SWAGGER_ENABLED=false        # /docs and /docs-json are opt-out (env.validation.ts); staging
#                                 # sits behind Cloudflare + Nginx with no auth in front of it, so
#                                 # the public OpenAPI surface must stay disabled there.
#   TRUST_PROXY_HOPS=2           # Cloudflare -> Nginx -> app. See docs/staging-runbook.md for the
#                                 # exact Nginx directives this depends on.
#   NODE_ENV=production          # required for env.validation.ts's production hardening checks
#                                 # (SESSION_SECRET/CSRF_SECRET length + distinctness,
#                                 # SESSION_COOKIE_SECURE=true, explicit CORS_ORIGIN).
