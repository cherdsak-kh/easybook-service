# Backend environment — copy to .env and adjust as needed.

# Port the NestJS server listens on.
PORT=3300

# Allowed CORS origin (the Vite dev server by default).
CORS_ORIGIN=http://localhost:2200

# Serve Swagger UI at /docs and the OpenAPI spec at /docs-json.
# Set to "false" to disable (e.g. in production).
SWAGGER_ENABLED=true

# PostgreSQL connection (Prisma). Copy this file to `.env` and set your password.
# Used by both the CLI/Migrate (prisma.config.ts) and the runtime pg adapter.
DATABASE_URL="postgresql://postgres_user:postgres_password@localhost:5432/database_name?schema=public"

# LINE Messaging API (from the Messaging API channel in the LINE Developers console).
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
