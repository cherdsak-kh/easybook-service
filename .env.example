# Backend environment — copy to .env and adjust as needed.

# Port the NestJS server listens on.
PORT=3300

# Allowed CORS origin (the Vite dev server by default).
# Cookie sessions + credentials:true make this a SECURITY CONTROL, not a convenience.
# Never "*", and never reflect the request Origin to work around it.
CORS_ORIGIN=http://localhost:2200

# Serve Swagger UI at /docs and the OpenAPI spec at /docs-json.
# Set to "false" to disable (e.g. in production).
SWAGGER_ENABLED=true

# Number of reverse-proxy hops in front of the app, for Express `trust proxy`. This is how
# many trusted proxies sit between the client and NestJS, and it makes req.ip / req.ips (and
# therefore the per-IP login rate limiter) resolve the REAL client IP from X-Forwarded-For.
# Staging chain is Cloudflare -> Nginx -> app, so 2. Use 0 for direct/local runs (no proxy).
# A hop COUNT is deliberate over a blanket "true": trusting the whole chain would let clients
# spoof X-Forwarded-For and evade the rate limiter. Defaults to 2 if unset/invalid.
TRUST_PROXY_HOPS=2

# PostgreSQL connection (Prisma). Copy this file to `.env` and set your password.
# Used by both the CLI/Migrate (prisma.config.ts) and the runtime pg adapter.
DATABASE_URL="postgresql://postgres_user:postgres_password@localhost:5432/database_name?schema=public"

# LINE Messaging API (from the Messaging API channel in the LINE Developers console).
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Login channel id — the numeric id of the LINE Login channel the LIFF app lives under.
# This is the `aud` of the id_token verified by LineIdTokenGuard, and is a DIFFERENT channel from
# the Messaging API one above. It is the prefix of the frontend's VITE_LIFF_ID ({channelId}-{suffix});
# do NOT derive it by string-splitting that frontend var. Required in production; digits only.
LINE_LOGIN_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Back-office authentication (SystemUser)
# ---------------------------------------------------------------------------

# Redis — backs the session store AND the login rate limiter. Required at boot.
# The app still boots when Redis is DOWN (it logs loudly, /health reports redis: "down",
# and session-backed requests fail closed with 503). It does NOT boot without this URL.
REDIS_URL=redis://default:password@localhost:6379/0

# Signs the eb.sid session cookie. Signs the CSRF token.
# The two MUST be different values. In production both must be >= 32 chars and must not be
# these placeholders — boot fails otherwise. Generate with: openssl rand -hex 32
SESSION_SECRET=dev-only-session-secret-change-me
CSRF_SECRET=dev-only-csrf-secret-change-me

# Session cookie. SESSION_COOKIE_SECURE must be "true" in production.
# SESSION_COOKIE_SAMESITE: lax | strict | none  ("none" requires SESSION_COOKIE_SECURE=true).
SESSION_COOKIE_NAME=eb.sid
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Rolling idle session lifetime, in seconds (default 28800 = 8h).
# The 24h absolute cap is a code constant, not configurable.
SESSION_TTL_SECONDS=28800

# Consumed ONLY by `npm run auth:seed-superadmin`. Never logged, never committed.
# The password must be at least 12 characters.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_SUPER_ADMIN_POSITION=System Administrator
SEED_SUPER_ADMIN_DEPARTMENT=IT
