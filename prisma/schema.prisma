// Prisma schema — easy-book-app backend.
// Domain models (User, Resource, Availability, Booking) are added in the
// domain-modelling task; this sets up the datasource + client generator only.
//
// Prisma 7: the connection URL lives in prisma.config.ts (for the CLI/Migrate)
// and is supplied to PrismaClient at runtime via a driver adapter (@prisma/adapter-pg).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Which rich menu a user is assigned (matches the two designs in assets/richmenu).
enum RichMenuType {
  TYPE_1
  TYPE_2
}

/// Whether a user may use the EasyBook app.
/// `UNREGISTERED` is the "zero" state a fresh follower lands on (before submitting the
/// registration form); it is deliberately the first value and the default on LineUser.
enum AppAccess {
  UNREGISTERED
  PENDING
  ALLOWED
  BLOCKED
}

/// A LINE user, created when they add the Official Account as a friend.
/// Soft-deleted (deletedAt) on unfollow; restored on re-follow.
model LineUser {
  id            String       @id @default(cuid())
  lineUserId    String       @unique
  displayName   String?
  pictureUrl    String?
  statusMessage String?
  language      String?
  richMenuType  RichMenuType @default(TYPE_1)
  access        AppAccess    @default(UNREGISTERED)
  followedAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  /// Back-relation for SystemUser.lineUser (DD-5). VIRTUAL — adds no column to line_users.
  /// Presence of a SystemUser here is a notification address, never an identity or a session.
  systemUser SystemUser? @relation("SystemUserLineAccount")

  /// Back-relation for the 1:1 registration a LINE user submits to move UNREGISTERED -> PENDING.
  /// VIRTUAL — adds no column to line_users. Nullable: a follower who never registered has none.
  registration LineUserRegistration? @relation("LineUserToRegistration")

  @@index([deletedAt])
  @@map("line_users")
}

/// Personnel identity a LINE end-user submits to move from UNREGISTERED -> PENDING.
/// 1:1 with LineUser. Holds PDPA-governed PII (real name, university ID, phone).
model LineUserRegistration {
  id String @id @default(cuid())

  /// FK -> LineUser.id (a cuid), NOT LineUser.lineUserId (the "U…" string). Same-name footgun as
  /// SystemUser.lineUserId — this is the cuid PK, the notification/identity target row. @unique
  /// makes the relation 1:1: one registration per LineUser.
  lineUserId String   @unique
  lineUser   LineUser @relation("LineUserToRegistration", fields: [lineUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  firstName String
  lastName  String

  /// University staff/personnel ID. Globally @unique — one ID identifies one person, so two
  /// registrations sharing an ID is a data error the DB rejects (P2002 -> 409 in the endpoint).
  /// Renamed from `studentStaffId` (SC-B1): the domain targets educational personnel/staff.
  staffId String @unique

  /// Loosely validated in the DTO (Thai formats), mirroring SystemUser.phoneNumber. Stored as given.
  phone String

  /// FK -> Department.id (an auto-increment Int). Required: every registration picks a department
  /// option (SC-2.4/Q4). `onDelete: Restrict` refuses a stray hard delete of a referenced option —
  /// normal deletes are soft (deletedAt), so a referenced row is never hard-deleted. Resolves for
  /// display even when the option is soft-deleted (the FK row persists; only deletedAt is set).
  departmentId Int
  department   Department @relation("RegistrationDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  /// FK -> PersonnelRole.id (an auto-increment Int; the LINE end-user's self-declared role — NOT
  /// SystemRole). Required.
  personnelRoleId Int
  personnelRole   PersonnelRole @relation("RegistrationPersonnelRole", fields: [personnelRoleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete parity column, reserved for a future right-to-erasure path. THIS feature never
  /// sets it and never cascades it from LineUser unfollow (registration persists across re-follow).
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([departmentId])
  @@index([personnelRoleId])
  @@map("line_user_registrations")
}

/// Admin-curated department/faculty options for the LINE registration form. Soft-deleted, never
/// hard-deleted. The active-name uniqueness is a PARTIAL unique index (`WHERE deletedAt IS NULL`,
/// authored in raw SQL in the migration — the PSL cannot express it), so `name` is deliberately NOT
/// `@unique` here: a soft-deleted name is REUSABLE (SC-2.3/Q2). Holds no PII.
model Department {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  registrations LineUserRegistration[] @relation("RegistrationDepartment")

  /// Back-relation for SystemUser.department. VIRTUAL — adds no column to departments.
  systemUsers SystemUser[] @relation("SystemUserDepartment")

  @@index([deletedAt])
  @@map("departments")
}

/// Admin-curated PERSONNEL role options (Teacher, Support Staff, …) — a JOB TITLE.
///
/// TWO consumers since 2026-07-16: (1) the LINE registration form — the end-user's self-declared
/// role; (2) back-office staff job titles (SystemUser.personnelRoleId, the former free-text
/// `position` column). One curated vocabulary, two readers.
///
/// CRITICAL: `PersonnelRole` is NOT `SystemRole`. `SystemRole` (SUPER_ADMIN | ADMIN | STAFF, on
/// SystemUser) is the back-office RBAC enum and the only grantor of privilege. They share NO table,
/// enum, type, endpoint, or seed, and never cross a code path. A `SystemUser` now holds BOTH: only
/// `SystemRole` grants privilege, and a `PersonnelRole` named "ADMIN" is a string — an inert label
/// on a STAFF user who still gets 403 everywhere. Never compare, map, or fall back between them.
/// Soft-deleted, name reusable (partial unique index — same as Department). Holds no PII.
model PersonnelRole {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  registrations LineUserRegistration[] @relation("RegistrationPersonnelRole")

  /// Back-relation for SystemUser.personnelRole. VIRTUAL — adds no column to personnel_roles.
  systemUsers SystemUser[] @relation("SystemUserPersonnelRole")

  @@index([deletedAt])
  @@map("personnel_roles")
}

/// Back-office operator role. Distinct from AppAccess (LINE consumer domain) by design.
enum SystemRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

/// A back-office operator. NOT a LINE end-customer — see LineUser.
///
/// Two INDEPENDENT lifecycle flags, never conflated (DD-4):
///   isActive = false  -> temporary, reversible suspension. The user still exists.
///   deletedAt != null -> soft deletion. The row is retained ONLY so the createdById audit
///                        chain stays resolvable. Invisible to every API route.
/// Both must be checked by SessionGuard and by login. See 02_design_log.md §1.1.
model SystemUser {
  id String @id @default(cuid())

  /// Always stored lowercase + trimmed. Normalised in the DTO transform AND in the service.
  /// Plain @unique spans soft-deleted rows: a deleted user's email is permanently burned (DD-6).
  email String @unique

  /// argon2id digest ("$argon2id$..."). Never selected into any DTO.
  passwordHash String

  firstName String
  lastName  String
  role      SystemRole @default(STAFF)

  /// Forced-reset flag. TRUE from the moment a temp password is issued (POST /system-users,
  /// POST /system-users/:id/reset-password); cleared ONLY by a successful POST /auth/system/password.
  /// camelCase, no @map — live columns in this schema are camelCase.
  ///
  /// ORTHOGONAL to isActive and deletedAt (a third independent flag, not a fourth lifecycle state):
  /// isActive=false is a suspension, deletedAt is soft deletion, and BOTH are 401s at SessionGuard —
  /// they fire FIRST, so a suspended or deleted user never reaches the reset screen. This flag is a
  /// CREDENTIAL state: the user is fully valid, they just may not do anything but change it (403).
  /// Enforced server-side in SessionGuard; a frontend redirect is UX, never the control.
  mustChangePassword Boolean @default(true)

  /// FK -> Department.id. Required: every staff member belongs to exactly one department option.
  /// Replaces the former free-text `department` column (DD-7 superseded by the PO, 2026-07-16 —
  /// see claude_planning/20260716_1342_staff_management/02_design_log.md §0). The values are still
  /// admin-curated DATA, never a Prisma enum, which is what DD-7 actually protected.
  ///
  /// `onDelete: Restrict` refuses a stray HARD delete of a referenced option. Normal option deletes
  /// are SOFT (deletedAt), so this rarely fires — and a soft-deleted option is still a live FK
  /// target, which is deliberate: READS ignore `deletedAt` (an existing assignment keeps resolving
  /// its name forever), WRITES require an ACTIVE option (checked in the service -> 400).
  departmentId Int
  department   Department @relation("SystemUserDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  /// FK -> PersonnelRole.id — the staff member's JOB TITLE ("Teacher", "Director"). The former
  /// free-text `position` column; "position" is the UI label, `personnelRole` is the model.
  ///
  /// CRITICAL: this is NOT `role` above. `role` is SystemRole (SUPER_ADMIN | ADMIN | STAFF) — the
  /// back-office RBAC enum and the ONLY thing that grants privilege. `personnelRole` is an
  /// admin-curated label that grants ZERO privilege, and a PersonnelRole named "ADMIN" is just a
  /// string. A SystemUser holds BOTH. They are never interchangeable, never compared, and never
  /// cross a code path. Any future `if (user.personnelRole.name === 'ADMIN')` is a privilege-
  /// escalation bug — the guard test in test/ exists to catch exactly that.
  personnelRoleId Int
  personnelRole   PersonnelRole @relation("SystemUserPersonnelRole", fields: [personnelRoleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  /// Display only. Loosely validated (Thai formats + office extensions).
  phoneNumber       String?
  /// https URL only. Rendered by the client; the backend NEVER fetches it. Written server-side by
  /// POST /auth/system/me/avatar (an R2 object URL); also settable to any https URL by an admin.
  profilePictureUrl String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  /// Soft delete (DD-4). NEVER exposed in any DTO. Set ONLY by DELETE /system-users/:id,
  /// cleared ONLY by POST /system-users/:id/restore. Filter `deletedAt: null` when resolving
  /// a user as an IDENTITY; never filter it when resolving createdById as HISTORY.
  deletedAt DateTime?

  /// Audit: which SUPER_ADMIN created this row. Null for the seeded first SUPER_ADMIN.
  /// Resolve WITHOUT a deletedAt filter — a deleted creator must still resolve (DD-4).
  createdById  String?
  createdBy    SystemUser?  @relation("SystemUserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdUsers SystemUser[] @relation("SystemUserCreatedBy")

  /// Optional 1-to-1 link to a personal LINE account, for future admin notifications (DD-5).
  /// FK -> LineUser.id (a cuid). NOT LineUser.lineUserId (the LINE-side "U..." identifier).
  /// Nullable + @unique => at most one SystemUser per LineUser; many SystemUsers may have none.
  /// NOT settable by ANY endpoint in this feature — absent from CreateSystemUserDto and
  /// UpdateSystemUserDto alike, so forbidNonWhitelisted 400s any attempt. Grants no authentication.
  lineUserId String?   @unique
  lineUser   LineUser? @relation("SystemUserLineAccount", fields: [lineUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([departmentId])
  @@index([personnelRoleId])
  @@map("system_users")
}
